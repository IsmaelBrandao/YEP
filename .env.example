# Credenciais do Supabase (Project Settings -> API)
# Copie este arquivo para .env e preencha com os valores do seu projeto.
EXPO_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sua-anon-public-key

# Token do Mapillary (fotos de rua dos postos) — gratuito.
# mapillary.com -> Profile -> Developers -> Registered Applications -> novo app -> Client Token
EXPO_PUBLIC_MAPILLARY_TOKEN=MLY|seu-token
